{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebFetch",
      "WebSearch",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(az:*)",
      "Bash(psql:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(tar:*)",
      "Bash(unzip:*)",
      "Bash(diff:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(xargs:*)",
      "Bash(tee:*)",
      "Bash(true)",
      "Bash(false)",
      "Bash(env)",
      "Bash(export:*)",
      "Bash(source:*)",
      "Bash(ping:*)",
      "Bash(nslookup:*)",
      "Bash(dig:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(make:*)",
      "Bash(prisma:*)",
      "Bash(MSYS_NO_PATHCONV=1 docker:*)",
      "Read(//Users/mikekunz/Documents/Volo Technologies/**)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /:*)",
      "Bash(sudo:*)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f*)",
      "Bash(git push origin master*)",
      "Bash(git push origin main*)",
      "Bash(git push origin +*)",
      "Bash(git push origin --delete master*)",
      "Bash(git push origin --delete main*)",
      "Bash(git push origin --delete staging*)",
      "Bash(git push origin -d master*)",
      "Bash(git push origin -d main*)",
      "Bash(git push origin -d staging*)",
      "Bash(git push origin :master*)",
      "Bash(git push origin :main*)",
      "Bash(git push origin :staging*)",
      "Bash(git push origin HEAD:master*)",
      "Bash(git push origin HEAD:main*)",
      "Bash(git push origin HEAD:staging*)",
      "Bash(git push * HEAD:master*)",
      "Bash(git push * HEAD:main*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(gh pr merge*)",
      "Bash(az containerapp delete*)",
      "Bash(az group delete*)",
      "Bash(psql*DROP DATABASE*)",
      "Bash(psql*DROP TABLE*)",
      "Bash(psql*TRUNCATE*)",
      "Bash(docker system prune*)",
      "Bash(docker volume rm*)",
      "Bash(npm publish*)",
      "Bash(npm unpublish*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/Users/mikekunz/Documents/Volo Technologies",
      "/Users/mikekunz/.claude/plans"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-guard.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/backlog-gate.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/block-protected-branch.sh" },
          { "type": "command", "command": "bash ~/.claude/hooks/block-no-verify.sh" },
          { "type": "command", "command": "bash ~/.claude/hooks/block-destructive-git.sh" },
          { "type": "command", "command": "bash ~/.claude/hooks/block-gh-merge.sh" },
          { "type": "command", "command": "bash ~/.claude/hooks/block-rebase-interactive.sh" },
          { "type": "command", "command": "bash ~/.claude/hooks/block-file-redirect.sh" },
          { "type": "command", "command": "bash ~/.claude/hooks/check-work-registration.sh" },
          { "type": "command", "command": "bash ~/.claude/hooks/check-branch-prefix.sh" }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/enforce-worktree.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/check-fix-landed.sh" }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "autoMode": {
    "allow": [
      "$defaults",
      "Post-merge git cleanup is pre-approved: `git worktree remove` (incl. --force) / `git worktree prune`, `git branch -d`/`-D`, and `git push origin --delete <branch>` for merged throwaway branches (feature/*, release/*, chore/backmerge*). Protected branches master, main, and staging stay deny-listed (never force-push or remote-delete them). Do not -D a branch that isn't confirmed merged."
    ]
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "skipAutoPermissionPrompt": true
}
