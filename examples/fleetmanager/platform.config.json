{
  "$schema": "../../platform.schema.json",
  "version": "1.0.0",
  "project": {
    "name": "fleetmanager-reservations",
    "repo": "TheLineExp/fleetmanager-reservations",
    "repoDir": "fleetmanager-reservations"
  },
  "branches": {
    "production": "master",
    "staging": "staging",
    "protected": ["master", "staging"],
    "featurePrefix": "feature/",
    "ownerPrefixes": ["mk"]
  },
  "agents": {
    "maxWindows": 3,
    "mergePolicy": "block-all"
  },
  "testing": {
    "command": "npm test",
    "runner": "docker-compose exec backend",
    "coverageThreshold": 50
  },
  "deployment": {
    "githubOrg": "TheLineExp",
    "githubRepo": "fleetmanager-reservations",
    "stagingUrl": "https://reservations-web-staging.proudriver-28095095.westus2.azurecontainerapps.io",
    "productionUrl": "https://reservations-web-prod.blackmeadow-d39ebc45.westus2.azurecontainerapps.io",
    "healthEndpoint": "/health"
  },
  "security": {
    "secretPatterns": [".env", ".env.*", "credentials*", "*secret*", "*.pem", "*.key", "prod_*.json"]
  },
  "permissions": {
    "preset": "power-user"
  }
}
