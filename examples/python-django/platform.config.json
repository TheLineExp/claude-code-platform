{
  "$schema": "../../platform.schema.json",
  "version": "1.0.0",
  "project": {
    "name": "my-django-app",
    "repo": "myorg/my-django-app",
    "repoDir": "my-django-app"
  },
  "branches": {
    "production": "main",
    "staging": "develop",
    "protected": ["main", "develop"],
    "featurePrefix": "feature/",
    "ownerPrefixes": ["mk"]
  },
  "agents": {
    "maxWindows": 2,
    "mergePolicy": "block-all"
  },
  "testing": {
    "command": "python manage.py test",
    "runner": "docker-compose exec web",
    "coverageThreshold": 60
  },
  "deployment": {
    "stagingUrl": "https://staging.example.com",
    "productionUrl": "https://app.example.com",
    "healthEndpoint": "/api/health/"
  },
  "security": {
    "secretPatterns": [".env", ".env.*", "credentials*", "*secret*", "*.pem", "*.key", "local_settings.py"]
  },
  "permissions": {
    "preset": "standard"
  }
}
